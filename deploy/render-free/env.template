NODE_ENV=production
PORT=3000
ENABLE_BACKGROUND_JOBS=false

# Public app URL on Render
CORS_ORIGIN=https://your-service-name.onrender.com

# Required infrastructure
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require
REDIS_URL=redis://default:<password>@<host>:<port>
SESSION_SECRET=<generate-a-long-random-secret>

# Optional scheduling (used only when background jobs are enabled)
DAILY_ORDER_CRON=0 2 * * *
DAILY_INVOICE_CRON=0 3 * * *

# First admin bootstrap (used only when running npm run bootstrap:admin)
AUTO_BOOTSTRAP_ADMIN=false
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=<set-a-strong-password>
ADMIN_NAME=Owner

# Optional notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
SMS_PROVIDER_URL=
SMS_API_KEY=
WEBHOOK_NOTIFICATION_URL=
