{
  "name": "milk-delivery-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted milk delivery and management platform",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev:server": "node --env-file=.env --import tsx src/server/index.ts",
    "dev:client": "vite --config src/client/vite.config.ts",
    "build:client": "vite build --config src/client/vite.config.ts",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/server/index.js",
    "test": "vitest --run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "bootstrap:admin": "tsx scripts/bootstrap-admin.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "@tanstack/react-query": "^5.75.5",
    "@types/web-push": "^3.6.4",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.34.8",
    "connect-redis": "^8.0.1",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "nodemailer": "^6.10.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.16.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "uuid": "^11.1.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/connect-redis": "^0.0.23",
    "@types/cors": "^2.8.17",
    "@types/csurf": "^1.11.5",
    "@types/express": "^5.0.2",
    "@types/express-session": "^1.18.1",
    "@types/node": "^22.15.18",
    "@types/nodemailer": "^6.4.17",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/pdfkit": "^0.13.8",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "fast-check": "^4.1.1",
    "postcss": "^8.5.3",
    "prisma": "^6.9.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.1.4"
  }
}
