# Local development environment
NODE_ENV=development
PORT=3000

# PostgreSQL — local setup
POSTGRES_USER=postgres
POSTGRES_PASSWORD=allow123
POSTGRES_DB=milkdelivery
DATABASE_URL=postgresql://postgres:allow123@localhost:5432/milkdelivery

# Redis
REDIS_URL=redis://localhost:6379

# Session & CSRF (dev values — don't use in production)
SESSION_SECRET=local-dev-session-secret-change-in-prod
CSRF_SECRET=local-dev-csrf-secret-change-in-prod

# Scheduling
DAILY_ORDER_CRON=0 2 * * *
MONTHLY_INVOICE_CRON=0 3 1 * *

# Business defaults
BILLING_CYCLE_START_DAY=1
CUTOFF_TIME=22:00
