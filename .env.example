# =============================================================================
# Milk Delivery Platform - Environment Variables
# Copy this file to .env and fill in the values before running.
# Never commit your populated .env file.
# =============================================================================

# ---- Application ----
NODE_ENV=production
PORT=3000
ENABLE_BACKGROUND_JOBS=true
CORS_ORIGIN=

# ---- PostgreSQL ----
POSTGRES_USER=milkdelivery
POSTGRES_PASSWORD=
POSTGRES_DB=milkdelivery
POSTGRES_PORT=5432
DATABASE_URL=postgresql://milkdelivery:<db-password>@postgres:5432/milkdelivery

# ---- Redis ----
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# ---- Session ----
SESSION_SECRET=

# ---- Optional Seed Credentials (development/demo only) ----
SEED_ADMIN_PASSWORD=
SEED_AGENT_PASSWORD=

# ---- Initial Production Admin Bootstrap ----
AUTO_BOOTSTRAP_ADMIN=false
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Super Admin

# ---- SMTP ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# ---- SMS ----
SMS_PROVIDER_URL=
SMS_API_KEY=

# ---- Webhook Notifications ----
WEBHOOK_NOTIFICATION_URL=

# ---- Web Push Notifications (VAPID) ----
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ---- Scheduling ----
DAILY_ORDER_CRON=0 2 * * *
DAILY_INVOICE_CRON=0 3 * * *

# ---- Business Defaults ----
BILLING_CYCLE_START_DAY=1
CUTOFF_TIME=22:00

# ---- Nginx / SSL ----
HTTP_PORT=80
HTTPS_PORT=443
SSL_CERT_DIR=./ssl

# ---- Backup ----
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
