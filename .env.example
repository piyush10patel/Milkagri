# =============================================================================
# Milk Delivery Platform — Environment Variables
# Copy this file to .env and fill in the values before running.
# =============================================================================

# ---- Application ----
NODE_ENV=production
PORT=3000

# ---- PostgreSQL ----
POSTGRES_USER=milkdelivery
POSTGRES_PASSWORD=          # REQUIRED — set a strong password
POSTGRES_DB=milkdelivery
POSTGRES_PORT=5432
# Full connection string (used by Prisma and the app)
DATABASE_URL=postgresql://milkdelivery:YOUR_PASSWORD@postgres:5432/milkdelivery

# ---- Redis ----
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# ---- Session ----
SESSION_SECRET=             # REQUIRED — random string, e.g. openssl rand -hex 32

# ---- CSRF ----
CSRF_SECRET=                # REQUIRED — random string for CSRF token signing

# ---- SMTP (email notifications) ----
SMTP_HOST=                  # e.g. smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# ---- SMS (stub — future integration) ----
SMS_PROVIDER_URL=           # e.g. https://sms-gateway.example.com/send
SMS_API_KEY=                # API key for the SMS provider

# ---- Webhook Notifications ----
WEBHOOK_NOTIFICATION_URL=   # e.g. https://hooks.example.com/notify — receives JSON POST payloads

# ---- Scheduling ----
# Cron expression for daily order generation (default: 2:00 AM)
DAILY_ORDER_CRON=0 2 * * *
# Cron expression for monthly invoice generation (default: 1st of month at 3:00 AM)
MONTHLY_INVOICE_CRON=0 3 1 * *

# ---- Business Defaults ----
# Day of month the billing cycle starts (1–28)
BILLING_CYCLE_START_DAY=1
# Cutoff time after which subscription changes apply next day (HH:mm, 24h)
CUTOFF_TIME=22:00

# ---- Nginx / SSL ----
HTTP_PORT=80
HTTPS_PORT=443
# Directory containing cert.pem and key.pem
SSL_CERT_DIR=./ssl

# ---- Backup ----
# Directory for PostgreSQL backup dumps
BACKUP_DIR=./backups
# Number of daily backups to retain
BACKUP_RETENTION_DAYS=30
