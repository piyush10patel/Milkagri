{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "composite": true,
    "outDir": "./dist/client",
    "rootDir": "./src/client",
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/client/*"]
    }
  },
  "include": ["src/client/**/*.ts", "src/client/**/*.tsx"],
  "exclude": ["src/client/**/*.test.ts", "src/client/**/*.test.tsx"]
}
